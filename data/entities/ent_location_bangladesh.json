  "facts": [
    {
      "text": "Bangladesh shares land borders with India to the north, west, and east, and Myanmar to the southeast.",
      "source_url": "https://en.wikipedia.org/wiki/Bangladesh",
      "source_type": "reference_work",
      "confidence_tier": "reported",
      "fact_id": "fct_001",
      "first_reported": "2026-07-16",
      "last_updated": "2026-07-16",
      "supersedes": null,
      "contradicted_by": null
    },
    {
      "text": "It has a coastline along the Bay of Bengal to its south and is separated from Bhutan and Nepal by the Siliguri Corridor, and from China by the Indian state of Sikkim to its north.",
      "source_url": "https://en.wikipedia.org/wiki/Bangladesh",
      "source_type": "reference_work",
      "confidence_tier": "reported",
      "fact_id": "fct_002",
      "first_reported": "2026-07-16",
      "last_updated": "2026-07-16",
      "supersedes": null,
      "contradicted_by": null
    },
    {
      "text": "Dhaka, the capital and largest city, is the nation's political, financial, and cultural centre.",
      "source_url": "https://en.wikipedia.org/wiki/Bangladesh",
      "source_type": "reference_work",
