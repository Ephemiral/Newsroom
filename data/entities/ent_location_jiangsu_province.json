      "contradicted_by": null
    },
    {
      "text": "Jiangsu has the highest GDP per capita and second-highest GDP of Chinese provinces, after Guangdong.",
      "source_url": "https://en.wikipedia.org/wiki/Jiangsu",
      "source_type": "reference_work",
      "confidence_tier": "reported",
