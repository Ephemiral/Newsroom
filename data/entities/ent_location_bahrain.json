  "facts": [
    {
      "text": "Bahrain is situated between Qatar and the northeastern coast of Saudi Arabia, to which it is connected by the King Fahd Causeway.",
      "source_url": "https://en.wikipedia.org/wiki/Bahrain",
      "source_type": "reference_work",
      "confidence_tier": "reported",
      "fact_id": "fct_001",
      "first_reported": "2026-07-08",
      "last_updated": "2026-07-08",
      "supersedes": null,
      "contradicted_by": null
    },
    {
      "text": "The population is 1,588,670 as of 2024, of whom 739,736 are Bahraini nationals, and 848,934 are expatriates.",
      "source_url": "https://en.wikipedia.org/wiki/Bahrain",
      "source_type": "reference_work",
      "confidence_tier": "reported",
      "fact_id": "fct_002",
      "first_reported": "2026-07-08",
      "last_updated": "2026-07-08",
      "supersedes": null,
      "contradicted_by": null
    },
    {
      "text": "Bahrain spans some 760 square kilometres (290 sq mi) and is the third-smallest nation in Asia after Maldives and Singapore.",
      "source_url": "https://en.wikipedia.org/wiki/Bahrain",
      "source_type": "reference_work",
