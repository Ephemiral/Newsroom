      "supersedes": null,
      "contradicted_by": null
    },
    {
      "text": "The country is a small city-state; most of the population reside in the urban agglomeration of Kuwait City, the capital and largest city.",
      "source_url": "https://en.wikipedia.org/wiki/Kuwait",
      "source_type": "reference_work",
