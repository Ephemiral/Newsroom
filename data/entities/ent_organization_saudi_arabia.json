      "contradicted_by": null
    },
    {
      "text": "The Gulf of Aqaba in the northwest separates Saudi Arabia from Egypt and Israel.",
      "source_url": "https://en.wikipedia.org/wiki/Saudi_Arabia",
      "source_type": "reference_work",
      "confidence_tier": "reported",
