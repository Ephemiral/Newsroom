  "facts": [
    {
      "text": "The UK includes the island of Great Britain, the north-eastern part of the island of Ireland, and most of the smaller islands within the British Isles, covering 94,354 square miles (244,376 km2).",
      "source_url": "https://en.wikipedia.org/wiki/United_Kingdom",
      "source_type": "reference_work",
      "confidence_tier": "reported",
      "fact_id": "fct_001",
      "first_reported": "2026-07-19",
      "last_updated": "2026-07-19",
      "supersedes": null,
      "contradicted_by": null
    },
    {
      "text": "It shares a land border with the Republic of Ireland and is surrounded by the Atlantic Ocean, the North Sea, the English Channel, the Celtic Sea and the Irish Sea, while maintaining sovereignty over the Crown Dependencies and the British Overseas Territories.",
      "source_url": "https://en.wikipedia.org/wiki/United_Kingdom",
      "source_type": "reference_work",
      "confidence_tier": "reported",
      "fact_id": "fct_002",
      "first_reported": "2026-07-19",
      "last_updated": "2026-07-19",
      "supersedes": null,
      "contradicted_by": null
    },
    {
      "text": "The capital and largest city of England and the UK is London; Edinburgh, Cardiff and Belfast are the national capitals of Scotland, Wales and Northern Ireland, respectively.",
      "source_url": "https://en.wikipedia.org/wiki/United_Kingdom",
      "source_type": "reference_work",
