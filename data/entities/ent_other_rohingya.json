  ],
  "image": null,
  "roles_affiliations": [],
  "connections": [],
  "facts": [
    {
      "text": "One of the most persecuted minorities in the world, the Rohingya are denied citizenship under the 1982 Myanmar nationality law.",
      "source_url": "https://en.wikipedia.org/wiki/Rohingya_people",
      "source_type": "reference_work",
      "confidence_tier": "reported",
      "fact_id": "fct_001",
      "first_reported": "2026-07-16",
      "last_updated": "2026-07-16",
      "supersedes": null,
      "contradicted_by": null
    },
    {
      "text": "There are also restrictions on their freedom of movement, access to state education and civil service jobs.",
      "source_url": "https://en.wikipedia.org/wiki/Rohingya_people",
      "source_type": "reference_work",
      "confidence_tier": "reported",
      "fact_id": "fct_002",
      "first_reported": "2026-07-16",
      "last_updated": "2026-07-16",
      "supersedes": null,
      "contradicted_by": null
    },
    {
      "text": "The legal conditions faced by the Rohingya in Myanmar have been compared to apartheid by some academics, analysts and political figures.",
      "source_url": "https://en.wikipedia.org/wiki/Rohingya_people",
      "source_type": "reference_work",
      "confidence_tier": "reported",
      "fact_id": "fct_003",
